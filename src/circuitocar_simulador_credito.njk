  <script>
    function formatEuro(value) {
      return new Intl.NumberFormat('pt-PT', { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 }).format(value);
    }

    function calcularSimulacao() {
      const preco = parseFloat(document.getElementById('precoViatura').value) || 0;
      const entrada = parseFloat(document.getElementById('entradaInicial').value) || 0;
      const prazo = parseInt(document.getElementById('prazoMeses').value, 10) || 0;
      const taxaAnual = parseFloat(document.getElementById('taxaAnual').value) || 0;
      const comissao = parseFloat(document.getElementById('comissaoInicial').value) || 0;
      const extraMensal = parseFloat(document.getElementById('seguroOpcional').value) || 0;
      const aviso = document.getElementById('mensagemAviso');

      aviso.style.display = 'none';
      aviso.textContent = '';

      if (preco <= 0 || prazo <= 0) {
        aviso.textContent = 'Introduza valores válidos para preço e prazo.';
        aviso.style.display = 'block';
        return;
      }
      if (entrada < 0 || comissao < 0 || extraMensal < 0) {
        aviso.textContent = 'Não use valores negativos na entrada, comissões ou extras.';
        aviso.style.display = 'block';
        return;
      }

      const montanteBase = preco - entrada;
      if (montanteBase <= 0) {
        aviso.textContent = 'A entrada inicial não pode ser igual ou superior ao preço da viatura.';
        aviso.style.display = 'block';
        return;
      }

      const montanteFinanciado = montanteBase + comissao;
      const taxaMensal = (taxaAnual / 100) / 12;
      let prestacaoBase = 0;

      if (taxaMensal === 0) {
        prestacaoBase = montanteFinanciado / prazo;
      } else {
        prestacaoBase = montanteFinanciado * (taxaMensal / (1 - Math.pow(1 + taxaMensal, -prazo)));
      }

      const prestacaoMensal = prestacaoBase + extraMensal;
      const totalPago = prestacaoMensal * prazo + entrada;
      const custoCredito = totalPago - preco;

      document.getElementById('prestacaoMensal').textContent = formatEuro(prestacaoMensal);
      document.getElementById('montanteFinanciado').textContent = formatEuro(montanteFinanciado);
      document.getElementById('totalPago').textContent = formatEuro(totalPago);
      document.getElementById('custoCredito').textContent = formatEuro(custoCredito);
    }

    function resetSimulacao() {
      document.getElementById('precoViatura').value = 18950;
      document.getElementById('entradaInicial').value = 3000;
      document.getElementById('prazoMeses').value = 60;
      document.getElementById('taxaAnual').value = 8.9;
      document.getElementById('comissaoInicial').value = 250;
      document.getElementById('seguroOpcional').value = 0;
      document.getElementById('mensagemAviso').style.display = 'none';
      calcularSimulacao();
    }

    calcularSimulacao();
  </script>

