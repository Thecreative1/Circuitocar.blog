  <!-- ── CALCULATOR + SIDEBAR ── -->
  <div class="sim-wrap">
    <div>
    <section class="sim-card" id="calculadora">
      <h2>Custo Mensal Real</h2>
      <p>Preencha os dados da viatura e do seu uso. Os valores sugeridos são médias realistas para Portugal — ajuste os que conhecer melhor.</p>

      <h3 class="group-title">A viatura</h3>
      <div class="form-grid">
        <div class="field">
          <label for="precoViatura">Preço da viatura (€)</label>
          <input class="input" id="precoViatura" type="number" min="1000" step="100" value="18950" aria-required="true" aria-describedby="hint-preco" />
          <small id="hint-preco">Valor total de venda.</small>
        </div>
        <div class="field">
          <label for="combustivel">Combustível</label>
          <select class="select" id="combustivel" aria-describedby="hint-combustivel" onchange="mudarCombustivel()">
            <option value="gasolina" selected>Gasolina</option>
            <option value="gasoleo">Gasóleo</option>
            <option value="hibrido">Híbrido</option>
            <option value="eletrico">Elétrico</option>
          </select>
          <small id="hint-combustivel">Atualiza consumo, preço de energia e IUC automaticamente.</small>
        </div>
        <div class="field">
          <label for="cilindrada">Cilindrada (cc)</label>
          <input class="input" id="cilindrada" type="number" min="0" max="8000" step="1" value="1200" aria-required="true" aria-describedby="hint-cilindrada" />
          <small id="hint-cilindrada">Consta na ficha técnica ou livrete. Usada para o IUC.</small>
        </div>
        <div class="field">
          <label for="co2">Emissões CO₂ (g/km)</label>
          <input class="input" id="co2" type="number" min="0" max="500" step="1" value="120" aria-required="true" aria-describedby="hint-co2" />
          <small id="hint-co2">Consta no DUA ou ficha técnica. Se não souber, deixe o valor sugerido.</small>
        </div>
        <div class="field">
          <label for="anoMatricula">Ano de matrícula</label>
          <input class="input" id="anoMatricula" type="number" min="2008" max="2026" step="1" value="2021" aria-required="true" aria-describedby="hint-ano" />
          <small id="hint-ano">Determina a norma de emissões usada no IUC (NEDC ou WLTP).</small>
        </div>
        <div class="field">
          <label for="kmAno">Quilómetros por ano</label>
          <input class="input" id="kmAno" type="number" min="0" max="100000" step="500" value="15000" aria-required="true" aria-describedby="hint-km" />
          <small id="hint-km">Média em Portugal: 12.000 a 15.000 km/ano.</small>
        </div>
      </div>

      <h3 class="group-title">Financiamento</h3>
      <div class="form-grid">
        <div class="field">
          <label for="prazoMeses">Prazo do crédito</label>
          <select class="select" id="prazoMeses" aria-describedby="hint-prazo">
            <option value="0">Sem financiamento (pronto pagamento)</option>
            <option value="36">36 meses</option>
            <option value="48">48 meses</option>
            <option value="60" selected>60 meses</option>
            <option value="72">72 meses</option>
            <option value="84">84 meses</option>
          </select>
          <small id="hint-prazo">Prazos longos baixam a prestação mas aumentam o custo total.</small>
        </div>
        <div class="field">
          <label for="entradaInicial">Entrada inicial (€)</label>
          <input class="input" id="entradaInicial" type="number" min="0" step="100" value="3000" aria-describedby="hint-entrada" />
          <small id="hint-entrada">Valor pago à cabeça. Ignorado se escolher pronto pagamento.</small>
        </div>
        <div class="field">
          <label for="taxaAnual">Taxa anual estimada (%)</label>
          <input class="input" id="taxaAnual" type="number" min="0" max="30" step="0.1" value="8.9" aria-describedby="hint-taxa" />
          <small id="hint-taxa">Valor indicativo — a taxa real depende do perfil e da financeira.</small>
        </div>
      </div>

      <h3 class="group-title">Custos de utilização</h3>
      <div class="form-grid">
        <div class="field">
          <label for="consumoMedio">Consumo médio (<span id="unidadeConsumo">L/100 km</span>)</label>
          <input class="input" id="consumoMedio" type="number" min="0" max="50" step="0.1" value="6.5" aria-describedby="hint-consumo" />
          <small id="hint-consumo">Sugerido pela média do tipo de motor. Ajuste ao carro concreto.</small>
        </div>
        <div class="field">
          <label for="precoEnergia">Preço (<span id="unidadePreco">€/litro</span>)</label>
          <input class="input" id="precoEnergia" type="number" min="0" max="5" step="0.01" value="1.72" aria-describedby="hint-energia" />
          <small id="hint-energia">Média nacional atual. Para elétricos, custo por kWh em casa.</small>
        </div>
        <div class="field">
          <label for="seguroMensal">Seguro mensal (€)</label>
          <input class="input" id="seguroMensal" type="number" min="0" step="1" value="30" aria-describedby="hint-seguro" />
          <small id="hint-seguro">Terceiros: 15–30 €/mês · Todos os riscos: 40–80 €/mês.</small>
        </div>
        <div class="field">
          <label for="manutencaoMensal">Manutenção mensal (€)</label>
          <input class="input" id="manutencaoMensal" type="number" min="0" step="1" value="35" aria-describedby="hint-manutencao" />
          <small id="hint-manutencao">Provisão para revisões, pneus e inspeção. Sugerida pelo tipo de motor.</small>
        </div>
      </div>

      <div class="calc-actions">
        <button class="cc-btn cc-btn--yellow" type="button" onclick="calcularCusto()"><i data-lucide="calculator"></i>Calcular custo mensal</button>
        <button class="cc-btn cc-btn--ghost-dark" type="button" onclick="resetCusto()"><i data-lucide="rotate-ccw"></i>Repor valores</button>
      </div>

      <div aria-live="polite" aria-atomic="false">
        <div class="result-grid">
          <div class="result-box highlight">
            <strong>Custo mensal total</strong>
            <span id="totalMensal">€ 0,00</span>
          </div>
          <div class="result-box">
            <strong>Custo anual total</strong>
            <span id="totalAnual">€ 0,00</span>
          </div>
