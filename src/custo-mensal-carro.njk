  <script>
    var PERFIL_COMBUSTIVEL = {
      gasolina: { consumo: 6.5, preco: 1.72, unidadeConsumo: 'L/100 km', unidadePreco: '€/litro', manutencao: 35, label: 'Combustível' },
      gasoleo:  { consumo: 4.8, preco: 1.68, unidadeConsumo: 'L/100 km', unidadePreco: '€/litro', manutencao: 45, label: 'Combustível' },
      hibrido:  { consumo: 5.0, preco: 1.72, unidadeConsumo: 'L/100 km', unidadePreco: '€/litro', manutencao: 40, label: 'Combustível' },
      eletrico: { consumo: 16,  preco: 0.22, unidadeConsumo: 'kWh/100 km', unidadePreco: '€/kWh', manutencao: 25, label: 'Energia' }
    };

    function formatEuro(value) {
      return new Intl.NumberFormat('pt-PT', { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 }).format(value);
    }

    function mudarCombustivel() {
      var fuel = document.getElementById('combustivel').value;
      var p = PERFIL_COMBUSTIVEL[fuel];
      document.getElementById('consumoMedio').value = p.consumo;
      document.getElementById('precoEnergia').value = p.preco;
      document.getElementById('manutencaoMensal').value = p.manutencao;
      document.getElementById('unidadeConsumo').textContent = p.unidadeConsumo;
      document.getElementById('unidadePreco').textContent = p.unidadePreco;
      document.getElementById('labelCombustivel').textContent = p.label;

      var eletrico = fuel === 'eletrico';
      var cil = document.getElementById('cilindrada');
      var co2 = document.getElementById('co2');
      cil.disabled = eletrico;
      co2.disabled = eletrico;
      if (eletrico) {
        cil.removeAttribute('aria-invalid');
        co2.removeAttribute('aria-invalid');
      }
      calcularCusto();
    }

    // IUC indicativo — categoria B (matrícula depois de julho 2007)
    function calcularIUC(fuel, cc, co2, ano) {
      if (fuel === 'eletrico') return 0;
      var compCilindrada = cc <= 1250 ? 31.87 : cc <= 1750 ? 63.94 : cc <= 2500 ? 127.72 : 437.06;
      var wltp = ano >= 2019;
      var compCO2;
      if (wltp) {
        compCO2 = co2 <= 140 ? 64.35 : co2 <= 205 ? 96.42 : co2 <= 260 ? 209.37 : 358.72;
      } else {
        compCO2 = co2 <= 120 ? 64.35 : co2 <= 180 ? 96.42 : co2 <= 250 ? 209.37 : 358.72;
      }
      var adicionalGasoleo = 0;
      if (fuel === 'gasoleo') {
        if (wltp) {
          adicionalGasoleo = co2 <= 140 ? 5.02 : co2 <= 205 ? 8.10 : co2 <= 260 ? 28.92 : 68.85;
        } else {
          adicionalGasoleo = co2 <= 120 ? 5.02 : co2 <= 180 ? 8.10 : co2 <= 250 ? 28.92 : 68.85;
        }
      }
      return compCilindrada + compCO2 + adicionalGasoleo;
    }

    function calcularCusto() {
      var fieldIds = ['precoViatura', 'cilindrada', 'co2', 'anoMatricula', 'kmAno', 'entradaInicial', 'taxaAnual', 'consumoMedio', 'precoEnergia', 'seguroMensal', 'manutencaoMensal'];
      var aviso = document.getElementById('mensagemAviso');

      fieldIds.forEach(function (id) {
        document.getElementById(id).removeAttribute('aria-invalid');
      });
      aviso.style.display = 'none';
      aviso.textContent = '';

      function showWarning(message, invalidIds) {
        (invalidIds || []).forEach(function (id) {
          document.getElementById(id).setAttribute('aria-invalid', 'true');
        });
        aviso.textContent = message;
        aviso.style.display = 'block';
        if (invalidIds && invalidIds.length) document.getElementById(invalidIds[0]).focus();
      }

      var fuel = document.getElementById('combustivel').value;
      var eletrico = fuel === 'eletrico';
      var preco = parseFloat(document.getElementById('precoViatura').value) || 0;
      var cc = eletrico ? 0 : parseFloat(document.getElementById('cilindrada').value) || 0;
      var co2 = eletrico ? 0 : parseFloat(document.getElementById('co2').value) || 0;
      var ano = parseInt(document.getElementById('anoMatricula').value, 10) || 0;
      var kmAno = parseFloat(document.getElementById('kmAno').value) || 0;
      var prazo = parseInt(document.getElementById('prazoMeses').value, 10) || 0;
      var entrada = parseFloat(document.getElementById('entradaInicial').value) || 0;
      var taxaAnual = parseFloat(document.getElementById('taxaAnual').value) || 0;
      var consumo = parseFloat(document.getElementById('consumoMedio').value) || 0;
      var precoEnergia = parseFloat(document.getElementById('precoEnergia').value) || 0;
      var seguro = parseFloat(document.getElementById('seguroMensal').value) || 0;
      var manutencao = parseFloat(document.getElementById('manutencaoMensal').value) || 0;

      if (preco <= 0) {
        showWarning('Introduza um preço de viatura válido.', ['precoViatura']);
        return;
      }
      if (!eletrico && cc <= 0) {
        showWarning('Introduza a cilindrada do motor (consta na ficha técnica ou livrete).', ['cilindrada']);
        return;
      }
      var anoAtual = new Date().getFullYear();
      if (ano < 2008 || ano > anoAtual) {
        showWarning('Introduza um ano de matrícula entre 2008 e ' + anoAtual + '. Para carros anteriores a julho de 2007, o IUC segue outra tabela — fale connosco.', ['anoMatricula']);
        return;
      }
      if (kmAno < 0 || kmAno > 100000) {
        showWarning('Introduza um valor de quilómetros anuais entre 0 e 100.000.', ['kmAno']);
        return;
      }
      if (prazo > 0 && entrada >= preco) {
        showWarning('A entrada inicial não pode ser igual ou superior ao preço da viatura.', ['entradaInicial']);
        return;
      }
      if (entrada < 0 || seguro < 0 || manutencao < 0 || consumo < 0 || precoEnergia < 0) {
        showWarning('Não use valores negativos.', []);
        return;
      }

      // 1. Prestação
      var prestacao = 0;
      if (prazo > 0) {
        var montante = preco - entrada;
        var taxaMensal = (taxaAnual / 100) / 12;
        prestacao = taxaMensal === 0
          ? montante / prazo
          : montante * (taxaMensal / (1 - Math.pow(1 + taxaMensal, -prazo)));
      }

      // 2. Combustível / energia
      var custoCombustivel = (kmAno / 12) * (consumo / 100) * precoEnergia;

      // 3. IUC mensalizado
      var iucAnual = calcularIUC(fuel, cc, co2, ano);
      var iucMensal = iucAnual / 12;

      // 4. Fixos
      var fixos = seguro + manutencao;

      var total = prestacao + custoCombustivel + iucMensal + fixos;

      document.getElementById('totalMensal').textContent = formatEuro(total);
      document.getElementById('totalAnual').textContent = formatEuro(total * 12);
      document.getElementById('resPrestacao').textContent = prazo > 0 ? formatEuro(prestacao) : 'Sem crédito';
      document.getElementById('resCombustivel').textContent = formatEuro(custoCombustivel);
      document.getElementById('resIuc').textContent = eletrico ? 'Isento' : formatEuro(iucMensal);
      document.getElementById('resFixos').textContent = formatEuro(fixos);

      // Breakdown bar
      if (total > 0) {
        document.getElementById('segPrestacao').style.width = (prestacao / total * 100) + '%';
        document.getElementById('segCombustivel').style.width = (custoCombustivel / total * 100) + '%';
        document.getElementById('segIuc').style.width = (iucMensal / total * 100) + '%';
        document.getElementById('segFixos').style.width = (fixos / total * 100) + '%';
      }

      // WhatsApp summary
      var resumo = 'Olá! Usei a calculadora de custo mensal do blog Circuito Car.\n'
        + 'Carro de ' + formatEuro(preco) + ' (' + fuel + ', ' + kmAno.toLocaleString('pt-PT') + ' km/ano)\n'
        + 'Custo mensal estimado: ' + formatEuro(total) + '\n'
        + '· Prestação: ' + (prazo > 0 ? formatEuro(prestacao) : 'sem crédito') + '\n'
        + '· Combustível/energia: ' + formatEuro(custoCombustivel) + '\n'
        + '· IUC: ' + (eletrico ? 'isento' : formatEuro(iucMensal) + '/mês') + '\n'
        + '· Seguro + manutenção: ' + formatEuro(fixos) + '\n'
        + 'Quero ver opções dentro deste orçamento.';
      document.getElementById('btnWhatsapp').href =
        '{{ site.contact.marco.whatsappBase }}?text=' + encodeURIComponent(resumo)
        + '&utm_source=simulador&utm_medium=resultado_whatsapp&utm_campaign=custo_mensal';
    }

    function resetCusto() {
      document.getElementById('precoViatura').value = 18950;
      document.getElementById('combustivel').value = 'gasolina';
      document.getElementById('cilindrada').value = 1200;
      document.getElementById('co2').value = 120;
      document.getElementById('anoMatricula').value = 2021;
      document.getElementById('kmAno').value = 15000;
      document.getElementById('prazoMeses').value = 60;
      document.getElementById('entradaInicial').value = 3000;
      document.getElementById('taxaAnual').value = 8.9;
      document.getElementById('mensagemAviso').style.display = 'none';
      mudarCombustivel();
    }

    mudarCombustivel();
  </script>

