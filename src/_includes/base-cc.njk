<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  <title>{{ pageTitle if pageTitle else title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta property="og:title" content="{{ ogTitle if ogTitle else title }}" />
  <meta property="og:description" content="{{ ogDescription if ogDescription else description }}" />
  <meta property="og:type" content="{{ ogType if ogType else 'website' }}" />
  <meta property="og:image" content="{{ heroImage if heroImage else site.logo }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="theme-color" content="#0A0B0D" />
  <link rel="icon" type="image/png" href="/img/logo-yellow.png" />

  <link rel="stylesheet" href="/css/circuito-car-tokens.css" />
  {% if inlineStyle %}<style>{{ inlineStyle | safe }}</style>{% endif %}
  {% if schemaOrg %}{{ schemaOrg | safe }}{% endif %}
</head>
<body>

  <header class="cc-topbar">
    <div class="cc-topbar__inner">
      <span class="cc-topbar__pill"><span class="cc-topbar__dot"></span>Stand em Joane · Famalicão</span>
      <div class="cc-topbar__links">
        <a href="{{ site.mainSite }}/viaturas?utm_source=blog&utm_medium=topbar_stock&utm_campaign=homepage">Ver stock</a>
        <a href="#contacto">Equipa</a>
        <a href="{{ site.mainSite }}/contactos?utm_source=blog&utm_medium=topbar_contactos&utm_campaign=homepage">Contactos</a>
      </div>
    </div>
  </header>

  <header class="cc-header">
    <div class="cc-header__inner">
      <a class="cc-header__logo" href="/" aria-label="Circuito Car — voltar à homepage">
        <img src="/img/logo-yellow.png" alt="Circuito Car" />
      </a>
      <span class="cc-header__brand-tag">Blog</span>
      <nav class="cc-header__nav" aria-label="Navegação principal">
        <a href="#artigos">Artigos</a>
        <a href="#ferramentas">Ferramentas</a>
        <a href="#local-seo">Onde estamos</a>
        <a href="#sobre">Sobre</a>
        <a href="{{ site.mainSite }}/viaturas?utm_source=blog&utm_medium=header_stock&utm_campaign=homepage">Viaturas</a>
      </nav>
      <a class="cc-header__cta" href="#contacto">
        <i data-lucide="message-square"></i>Falar connosco
      </a>
    </div>
  </header>

  {{ content | safe }}

  <footer class="cc-footer">
    <div class="cc-footer__inner">
      <div class="cc-footer__grid">
        <div class="cc-footer__col cc-footer__brand">
          <img src="/img/logo-yellow.png" alt="Circuito Car" class="cc-footer__logo" />
          <p>Guias e ferramentas para quem quer comprar carro usado no eixo Famalicão, Braga e Guimarães — com a equipa do stand a um WhatsApp de distância.</p>
        </div>
        <div class="cc-footer__col">
          <h4>Explorar</h4>
          <a href="#artigos">Artigos</a>
          <a href="#ferramentas">Ferramentas</a>
          <a href="#stock">Stock em destaque</a>
          <a href="{{ site.mainSite }}/viaturas?utm_source=blog&utm_medium=footer_stock&utm_campaign=homepage">Ver stock completo</a>
        </div>
        <div class="cc-footer__col">
          <h4>Contacto</h4>
          <a href="#contacto">Falar com a equipa</a>
          <a href="{{ site.mainSite }}/contactos?utm_source=blog&utm_medium=footer_contactos&utm_campaign=homepage">Página de contactos</a>
          <a href="/circuitocar_simulador_credito.html">Simulador de crédito</a>
          <a href="/simulador_retoma.html">Simulador de retoma</a>
        </div>
        <div class="cc-footer__col">
          <h4>Localização</h4>
          <p style="margin:0">{{ site.address.street }}<br>{{ site.address.zip }} {{ site.address.city }}<br>{{ site.address.region }}</p>
        </div>
      </div>
      <div class="cc-footer__bottom">
        <span>© 2026 Circuito Car. Todos os direitos reservados.</span>
        <span>{{ footerNote if footerNote else 'Stand em Joane, Vila Nova de Famalicão · circuitocar.pt' }}</span>
      </div>
    </div>
  </footer>

  <nav class="cc-mobile-dock" aria-label="Navegação mobile">
    <a href="/"><i data-lucide="home"></i><span>Início</span></a>
    <a href="#artigos"><i data-lucide="book-open"></i><span>Blog</span></a>
    <a href="/circuitocar_simulador_credito.html"><i data-lucide="calculator"></i><span>Crédito</span></a>
    <a href="/simulador_retoma.html"><i data-lucide="repeat"></i><span>Retoma</span></a>
    <a href="#contacto"><i data-lucide="message-square"></i><span>Contacto</span></a>
  </nav>

  <script src="https://unpkg.com/lucide@latest"></script>
  <script>lucide.createIcons();</script>
</body>
</html>
