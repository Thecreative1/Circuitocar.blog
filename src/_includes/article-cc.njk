<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  <title>{{ pageTitle if pageTitle else title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta property="og:title" content="{{ ogTitle if ogTitle else title }}" />
  <meta property="og:description" content="{{ ogDescription if ogDescription else description }}" />
  <meta property="og:type" content="article" />
  <meta property="og:image" content="{{ ogImage if ogImage else (heroImage if heroImage else site.logo) }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:site_name" content="{{ site.title }}" />
  <meta property="og:locale" content="pt_PT" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ ogTitle if ogTitle else title }}" />
  <meta name="twitter:description" content="{{ ogDescription if ogDescription else description }}" />
  <meta name="twitter:image" content="{{ ogImage if ogImage else (heroImage if heroImage else site.logo) }}" />
  <meta name="theme-color" content="#0A0B0D" />
  <link rel="icon" type="image/png" href="{{ site.basePath }}/img/logo-yellow.png" />
  <link rel="apple-touch-icon" href="{{ site.basePath }}/img/logo-yellow.png" />
  <link rel="alternate" type="application/rss+xml" title="Circuito Car Blog" href="{{ site.url }}/rss.xml" />
  {% include "google-tag.njk" %}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Saira+Condensed:ital,wght@0,500;0,700;0,800;0,900;1,700;1,800;1,900&family=Manrope:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Saira+Condensed:ital,wght@0,500;0,700;0,800;0,900;1,700;1,800;1,900&family=Manrope:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" />

  <link rel="stylesheet" href="{{ site.basePath }}/css/circuito-car-tokens.css" />
  <link rel="stylesheet" href="{{ site.basePath }}/css/article-cc.css" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ title | dump | safe }},
    "description": {{ description | dump | safe }},
    "datePublished": "{{ date | dateIso }}",
    "dateModified": "{{ (lastmod if lastmod else date) | dateIso }}",
    "url": "{{ site.url }}{{ page.url }}",
    "image": "{{ heroImage if heroImage else site.logo }}",
    "author": { "@type": "Organization", "name": "Circuito Car" },
    "publisher": {
      "@type": "Organization",
      "name": "Circuito Car",
      "logo": { "@type": "ImageObject", "url": "{{ site.url }}/img/logo-yellow.png" }
    }
  }
  </script>
  {% if schemaOrg %}{{ schemaOrg | safe }}{% endif %}
</head>
<body>

  <a class="cc-skip-link" href="#cc-main">Saltar para o conteúdo</a>

  <div class="cc-topbar">
    <div class="cc-topbar__inner">
      <span class="cc-topbar__pill"><span class="cc-topbar__dot"></span>Stand em Joane · Famalicão</span>
      <div class="cc-topbar__links">
        <a href="{{ site.mainSite }}/viaturas?utm_source=blog&utm_medium=topbar_stock&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer">Ver stock</a>
        <a href="#equipa">Equipa</a>
        <a href="{{ site.basePath }}/#contacto">Contactos</a>
      </div>
    </div>
  </div>

  <header class="cc-header">
    <div class="cc-header__inner">
      <a class="cc-header__logo" href="{{ site.basePath }}/" aria-label="Circuito Car — voltar à homepage">
        <img src="{{ site.basePath }}/img/logo-yellow.png" alt="Circuito Car" width="316" height="86" />
      </a>
      <span class="cc-header__brand-tag">Blog</span>
      <nav class="cc-header__nav" aria-label="Navegação principal">
        <a href="{{ site.basePath }}/artigos.html" aria-current="true">Artigos</a>
        <a href="{{ site.basePath }}/#ferramentas">Ferramentas</a>
        <a href="{{ site.basePath }}/#local-seo">Onde estamos</a>
        <a href="{{ site.basePath }}/#sobre">Sobre</a>
        <a href="{{ site.mainSite }}/viaturas?utm_source=blog&utm_medium=header_stock&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer">Viaturas</a>
      </nav>
      <a class="cc-header__cta" href="#equipa">
        <i data-lucide="message-square"></i>Falar connosco
      </a>
    </div>
  </header>

  <main id="cc-main">

  <!-- ── POST HERO (dark) ── -->
  <section class="cc-post-hero">
    <div class="cc-post-hero__inner">
      <span class="cc-post-hero__eyebrow">Blog · {{ category }}</span>
      <h1>{{ title }}</h1>
      <p class="cc-post-hero__lead">{{ lead | safe }}</p>
      <div class="cc-post-hero__meta">
        <span><i data-lucide="clock"></i>{{ readTime }}</span>
        <span>·</span>
        <span><i data-lucide="calendar"></i>{{ date | dateReadable }}</span>
        <span>·</span>
        <span><i data-lucide="map-pin"></i>Joane, Famalicão</span>
      </div>
      <div class="cc-post-hero__actions">
        <a class="cc-btn cc-btn--yellow" href="{{ site.mainSite }}/viaturas?utm_source=blog&utm_medium=hero_stock&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer"><i data-lucide="car"></i>Ver viaturas disponíveis</a>
        <a class="cc-btn cc-btn--ghost-light" href="{{ site.contact.marco.whatsappBase }}?text={{ heroWhatsappMsg | urlencode }}&utm_source=blog&utm_medium=hero_whatsapp&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer"><i data-lucide="message-circle"></i>WhatsApp Circuito Car</a>
      </div>
    </div>
    <div class="cc-post-hero__chevron" aria-hidden="true"></div>
  </section>

  <!-- Cover image (bleeds into next section) -->
  {% if heroImage %}
  <div class="cc-post-cover">
    <a href="{{ heroImageLink }}?utm_source=blog&utm_medium=hero_image&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer" aria-label="{{ heroImageAlt }}">
      <img class="cc-post-cover__img" src="{{ heroImage }}" alt="{{ heroImageAlt }}" width="1200" height="675" loading="lazy" />
    </a>
  </div>
  {% endif %}

  <!-- ── SHARE (top) ── -->
  {% set shareModifier = "top" %}
  {% include "article-share.njk" %}

  <!-- ── ARTICLE + SIDEBAR ── -->
  <div class="cc-post-wrap">
    <article class="cc-prose">
      {{ content | safe }}
    </article>

    <aside class="cc-sidebar" id="equipa">

      {% if inventoryUrl %}
      <div class="cc-side-card cc-side-card--stock">
        <span class="cc-side-card__eyebrow">Stock disponível</span>
        <h3>{{ inventoryLabel if inventoryLabel else "Ver viaturas disponíveis" }}</h3>
        <p>Viaturas verificadas, com garantia, disponíveis agora no stand em Joane.</p>
        <a class="cc-btn cc-btn--yellow" style="width:100%;justify-content:center;" href="{{ inventoryUrl }}&utm_source=blog&utm_medium=sidebar_stock&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer"><i data-lucide="car"></i>{{ inventoryLabel if inventoryLabel else "Ver viaturas" }}</a>
      </div>
      {% endif %}

      <div class="cc-side-card cc-side-card--warm">
        <span class="cc-side-card__eyebrow">{{ sidebarBadge }}</span>
        <h3>{{ sidebarTitle }}</h3>
        <p>{{ sidebarDescription }}</p>
      </div>

      <div class="cc-side-card">
        <span class="cc-side-card__eyebrow">Mais no blog</span>
        <h3>Continuar a ler</h3>
        {% for rel in relatedArticles %}
          <a href="{{ site.basePath }}/{{ rel.url }}" class="cc-side-link">{{ rel.title }}</a>
        {% endfor %}
      </div>

      <div class="cc-side-card">
        <span class="cc-side-card__eyebrow">Contacto</span>
        <h3>Fala com a Circuito Car</h3>

        <!-- Marco — primary, blue-accented -->
        <div class="cc-side-seller" style="border-top: 3px solid var(--cc-blue-light); background: var(--cc-paper-card);">
          <div class="cc-side-seller__top">
            <strong>{{ site.contact.marco.name }}</strong>
            <span class="cc-side-seller__role" style="background: var(--cc-blue-light); color: var(--cc-paper);">{{ site.contact.marco.role }}</span>
          </div>
          <p>Disponível para informações sobre viaturas, marcar visitas, esclarecer dúvidas de financiamento e retoma — e encaminha para a pessoa certa se necessário.</p>
          <div class="cta-actions">
            <a class="cc-btn cc-btn--dark" href="tel:{{ site.contact.marco.phone }}"><i data-lucide="phone"></i>Ligar para a CircuitoCar</a>
            <a class="cc-btn cc-btn--wa" href="{{ site.contact.marco.whatsappBase }}?text={{ sidebarWhatsappMsg | urlencode }}&utm_source=blog&utm_medium=sidebar_marco&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer"><i data-lucide="message-circle"></i>Falar com a CircuitoCar</a>
          </div>
        </div>

        <!-- Divider -->
        <div style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
          <span style="font-family: var(--cc-font-display); font-style: italic; font-weight: var(--cc-fw-bold); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--cc-fg-subtle); white-space: nowrap;">Direção</span>
          <div style="flex: 1; height: 1px; background: var(--cc-border);"></div>
        </div>

        <!-- André — director -->
        <div class="cc-side-seller">
          <div class="cc-side-seller__top">
            <strong>{{ site.contact.andre.name }}</strong>
            <span class="cc-side-seller__role">{{ site.contact.andre.role }}</span>
          </div>
          <p>{{ andreDescription }}</p>
          <div class="cta-actions">
            <a class="cc-btn cc-btn--dark" href="tel:{{ site.contact.andre.phone }}"><i data-lucide="phone"></i>Ligar</a>
            <a class="cc-btn cc-btn--wa" href="{{ site.contact.andre.whatsappBase }}?text={{ sidebarWhatsappMsg | urlencode }}&utm_source=blog&utm_medium=sidebar_andre&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer"><i data-lucide="message-circle"></i>WhatsApp</a>
          </div>
        </div>

        <!-- Filipe — director -->
        <div class="cc-side-seller">
          <div class="cc-side-seller__top">
            <strong>{{ site.contact.filipe.name }}</strong>
            <span class="cc-side-seller__role">{{ site.contact.filipe.role }}</span>
          </div>
          <p>{{ filipeDescription }}</p>
          <div class="cta-actions">
            <a class="cc-btn cc-btn--dark" href="tel:{{ site.contact.filipe.phone }}"><i data-lucide="phone"></i>Ligar</a>
            <a class="cc-btn cc-btn--wa" href="{{ site.contact.filipe.whatsappBase }}?text={{ sidebarWhatsappMsg | urlencode }}&utm_source=blog&utm_medium=sidebar_filipe&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer"><i data-lucide="message-circle"></i>WhatsApp</a>
          </div>
        </div>
      </div>

    </aside>
  </div>

  <!-- ── SHARE (bottom) ── -->
  {% set shareModifier = "bottom" %}
  {% include "article-share.njk" %}

  <!-- ── RELATED ARTICLES ── -->
  {% if relatedArticles and relatedArticles.length %}
  <section class="cc-related">
    <div class="cc-related__inner">
      <h3>Mais guias para <em>ler</em></h3>
      <div class="cc-related__grid">
        {% for rel in relatedArticles %}
          <a class="cc-related-card" href="{{ site.basePath }}/{{ rel.url }}">
            <span class="cc-related-card__eyebrow">Artigo</span>
            <h3 class="cc-related-card__title">{{ rel.title }}</h3>
          </a>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  </main>

  <footer class="cc-footer">
    <div class="cc-footer__inner">
      <div class="cc-footer__grid">
        <div class="cc-footer__col cc-footer__brand">
          <img src="{{ site.basePath }}/img/logo-yellow.png" alt="Circuito Car" class="cc-footer__logo" width="316" height="86" loading="lazy" />
          <p>Stand automóvel em Joane, Vila Nova de Famalicão. Viaturas usadas verificadas, com garantia e financiamento próprio.</p>
        </div>
        <div class="cc-footer__col">
          <h4>Explorar</h4>
          <a href="{{ site.basePath }}/artigos.html">Artigos</a>
          <a href="{{ site.basePath }}/#ferramentas">Ferramentas</a>
          <a href="{{ site.basePath }}/#stock">Stock em destaque</a>
          <a href="{{ site.mainSite }}/viaturas?utm_source=blog&utm_medium=footer_stock&utm_campaign={{ utmCampaign }}" target="_blank" rel="noopener noreferrer">Ver stock completo</a>
        </div>
        <div class="cc-footer__col">
          <h4>Contacto</h4>
          <a href="#equipa">Falar com a equipa</a>
          <a href="{{ site.basePath }}/simulador_isv.html">Simulador de ISV</a>
          <a href="{{ site.basePath }}/circuitocar_simulador_credito.html">Simulador de crédito</a>
          <a href="{{ site.basePath }}/simulador_retoma.html">Simulador de retoma</a>
        </div>
        <div class="cc-footer__col">
          <h4>Localização</h4>
          <p style="margin:0">{{ site.address.street }}<br>{{ site.address.zip }} {{ site.address.city }}<br>{{ site.address.region }}</p>
        </div>
      </div>
      <div class="cc-footer__bottom">
        <span>© 2026 Circuito Car. Todos os direitos reservados.</span>
        <span>{{ footerNote if footerNote else 'Stand em Joane, Vila Nova de Famalicão · circuitocar.pt' }}</span>
      </div>
      <div class="cc-credit">
        <a href="https://thecreative1.github.io/Estudio-Flavio-Martins/" target="_blank" rel="noopener noreferrer">
          <i data-lucide="feather"></i>desenvolvido por Estúdio Flávio Martins
        </a>
      </div>
    </div>
  </footer>

  <nav class="cc-mobile-dock" aria-label="Navegação mobile">
    <a href="{{ site.basePath }}/"><i data-lucide="home"></i><span>Início</span></a>
    <a href="{{ site.basePath }}/artigos.html"><i data-lucide="book-open"></i><span>Blog</span></a>
    <a href="{{ site.basePath }}/simulador_isv.html"><i data-lucide="file-search"></i><span>ISV</span></a>
    <a href="{{ site.basePath }}/circuitocar_simulador_credito.html"><i data-lucide="calculator"></i><span>Crédito</span></a>
    <a href="#equipa"><i data-lucide="message-square"></i><span>Contacto</span></a>
  </nav>

  <script src="{{ site.basePath }}/assets/lucide.min.js"></script>
  <script>lucide.createIcons({ attrs: { 'aria-hidden': 'true', focusable: 'false' } });</script>

  <script>
  (function () {
    var pageUrl  = window.location.origin + window.location.pathname;
    var pageTitle = document.title;
    var pageDesc  = (document.querySelector('meta[name="description"]') || {}).content || '';
    var campaign  = 'article_share';

    function tagged(source) {
      return pageUrl + '?utm_source=' + source + '&utm_medium=social&utm_campaign=' + campaign;
    }

    var urls = {
      whatsapp: 'https://wa.me/?text='    + encodeURIComponent(pageTitle + ' ' + tagged('whatsapp')),
      facebook: 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(tagged('facebook')),
      x:        'https://twitter.com/intent/tweet?text=' + encodeURIComponent(pageTitle) + '&url=' + encodeURIComponent(tagged('x')),
      linkedin: 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(tagged('linkedin')),
      telegram: 'https://t.me/share/url?url=' + encodeURIComponent(tagged('telegram')) + '&text=' + encodeURIComponent(pageTitle),
      email:    'mailto:?subject=' + encodeURIComponent(pageTitle) + '&body=' + encodeURIComponent(pageTitle + '\n\n' + tagged('email'))
    };

    /* Set hrefs on all platform anchors */
    document.querySelectorAll('[data-share]').forEach(function (el) {
      var platform = el.dataset.share;
      if (urls[platform]) el.href = urls[platform];
    });

    /* Native share */
    var nativeBtns = document.querySelectorAll('[data-share-action="native"]');
    if (typeof navigator.share === 'function') {
      nativeBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          navigator.share({
            title: pageTitle,
            text:  pageDesc,
            url:   tagged('native_share')
          }).catch(function () {});
        });
      });
    } else {
      nativeBtns.forEach(function (btn) { btn.style.display = 'none'; });
    }

    /* Copy link */
    document.querySelectorAll('[data-share-action="copy"]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var copyUrl = tagged('copy');
        function showFeedback() {
          btn.classList.add('is-copied');
          setTimeout(function () { btn.classList.remove('is-copied'); }, 2200);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(copyUrl).then(showFeedback).catch(showFeedback);
        } else {
          var ta = document.createElement('textarea');
          ta.value = copyUrl;
          ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); } catch (e) {}
          document.body.removeChild(ta);
          showFeedback();
        }
      });
    });
  })();
  </script>
</body>
</html>
