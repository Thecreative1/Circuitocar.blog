<div class="article-share article-share--{{ shareModifier or 'top' }}" aria-label="Partilhar artigo">
  <div class="article-share__inner">
    <span class="article-share__label">Partilhar artigo</span>
    <div class="article-share__buttons">
      <button class="article-share__button article-share__button--native" type="button" data-share-action="native" aria-label="Partilhar via opção nativa do dispositivo">
        <i data-lucide="share-2"></i><span>Partilhar</span>
      </button>
      <a class="article-share__button" data-share="whatsapp" href="#" target="_blank" rel="noopener noreferrer" aria-label="Partilhar no WhatsApp">WhatsApp</a>
      <a class="article-share__button" data-share="facebook" href="#" target="_blank" rel="noopener noreferrer" aria-label="Partilhar no Facebook">Facebook</a>
      <a class="article-share__button" data-share="x" href="#" target="_blank" rel="noopener noreferrer" aria-label="Partilhar no X">X</a>
      <a class="article-share__button" data-share="linkedin" href="#" target="_blank" rel="noopener noreferrer" aria-label="Partilhar no LinkedIn">LinkedIn</a>
      <a class="article-share__button" data-share="telegram" href="#" target="_blank" rel="noopener noreferrer" aria-label="Partilhar no Telegram">Telegram</a>
      <a class="article-share__button" data-share="email" href="#" aria-label="Partilhar por email">
        <i data-lucide="mail"></i>Email
      </a>
      <button class="article-share__button article-share__button--copy" type="button" data-share-action="copy" aria-label="Copiar link do artigo">
        <i data-lucide="link"></i>
        <span class="article-share__text">Copiar link</span>
        <span class="article-share__feedback" aria-live="polite" aria-atomic="true">Link copiado!</span>
      </button>
    </div>
  </div>
</div>
