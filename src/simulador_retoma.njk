  <style>
    /* ----- Trade-in simulator specific styles ----- */
    .sim-wrap { max-width: 1280px; margin: 0 auto; padding: 56px 32px 96px; display: grid; grid-template-columns: minmax(0, 1fr) 340px; gap: 40px; align-items: start; }

    .panel { background: var(--cc-paper-card); border: 1px solid var(--cc-border); border-radius: var(--cc-radius-lg); padding: 36px; }
    .panel-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 18px; margin-bottom: 28px; flex-wrap: wrap; }
    .panel-header h2 { font-family: var(--cc-font-display); font-style: italic; font-weight: var(--cc-fw-black); text-transform: uppercase; font-size: clamp(24px, 2.4vw, 34px); line-height: 1.05; letter-spacing: var(--cc-tracking-tight); color: var(--cc-ink); margin: 0 0 10px; }
    .panel-header p { font-family: var(--cc-font-body); font-size: var(--cc-fs-base); line-height: var(--cc-lh-loose); color: var(--cc-fg-muted); margin: 0; max-width: 620px; }
    .panel-header .badge { display: inline-block; font-family: var(--cc-font-display); font-style: italic; font-weight: var(--cc-fw-black); font-size: var(--cc-fs-xs); letter-spacing: var(--cc-tracking-wider); text-transform: uppercase; padding: 6px 12px; border-radius: var(--cc-radius-pill); background: var(--cc-yellow); color: var(--cc-ink); white-space: nowrap; }

    .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .field { display: flex; flex-direction: column; gap: 6px; }
    .field.full { grid-column: 1 / -1; }
    .field label { font-family: var(--cc-font-display); font-style: italic; font-weight: var(--cc-fw-bold); font-size: var(--cc-fs-xs); color: var(--cc-fg-muted); letter-spacing: var(--cc-tracking-wider); text-transform: uppercase; }
    .field input, .field select, .field textarea { font-family: var(--cc-font-body); font-size: var(--cc-fs-md); font-weight: var(--cc-fw-semibold); color: var(--cc-ink); background: var(--cc-paper-warm); border: 1px solid var(--cc-border-strong); border-radius: var(--cc-radius-sm); padding: 12px 14px; outline: none; transition: border-color var(--cc-dur-fast) var(--cc-ease-out), box-shadow var(--cc-dur-fast) var(--cc-ease-out); width: 100%; }
    .field input:focus, .field select:focus, .field textarea:focus { border-color: var(--cc-ink); box-shadow: var(--cc-shadow-yellow); }
    .field textarea { resize: vertical; min-height: 96px; line-height: 1.55; font-weight: var(--cc-fw-regular); }
    .field .hint { font-family: var(--cc-font-body); font-size: var(--cc-fs-xs); color: var(--cc-fg-subtle); line-height: 1.4; }

    .checkbox-row { display: flex; align-items: flex-start; gap: 10px; margin: 22px 0; padding: 16px; background: var(--cc-paper-warm); border: 1px solid var(--cc-border); border-radius: var(--cc-radius-md); }
    .checkbox-row input[type="checkbox"] { width: 18px; height: 18px; margin-top: 2px; accent-color: var(--cc-yellow-deep); flex-shrink: 0; }
    .checkbox-row label { font-family: var(--cc-font-body); font-size: var(--cc-fs-sm); color: var(--cc-fg-muted); line-height: 1.5; }

    .actions { display: flex; gap: 10px; flex-wrap: wrap; }

    .results { display: none; margin-top: 36px; padding-top: 28px; border-top: 1px solid var(--cc-border); }
    .results.active { display: block; }
    .result-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 22px; }
    .result-card { background: var(--cc-paper-warm); border: 1px solid var(--cc-border); border-radius: var(--cc-radius-md); padding: 18px 20px; }
    .result-card:first-child { background: var(--cc-ink); border-color: var(--cc-ink); }
    .result-card:first-child .result-label { color: var(--cc-yellow); }
    .result-card:first-child .result-value { color: var(--cc-yellow); }
    .result-card:first-child .result-text { color: var(--cc-asphalt-300); }
    .result-label { font-family: var(--cc-font-display); font-style: italic; font-weight: var(--cc-fw-bold); font-size: var(--cc-fs-xs); color: var(--cc-fg-muted); letter-spacing: var(--cc-tracking-wider); text-transform: uppercase; display: block; margin-bottom: 8px; }
    .result-value { font-family: var(--cc-font-display); font-style: italic; font-weight: var(--cc-fw-black); font-size: var(--cc-fs-2xl); color: var(--cc-ink); letter-spacing: var(--cc-tracking-tight); line-height: 1; margin-bottom: 8px; }
    .result-text { font-family: var(--cc-font-body); font-size: var(--cc-fs-xs); color: var(--cc-fg-subtle); line-height: 1.5; }

    .score-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--cc-border); border: 1px solid var(--cc-border); border-radius: var(--cc-radius-md); overflow: hidden; margin-bottom: 22px; }
    .score-item { background: var(--cc-paper-card); padding: 14px 16px; text-align: center; }
    .score-item strong { display: block; font-family: var(--cc-font-body); font-size: var(--cc-fs-sm); font-weight: var(--cc-fw-bold); color: var(--cc-ink); margin-bottom: 4px; line-height: 1.2; }
    .score-item span { font-family: var(--cc-font-display); font-style: italic; font-weight: var(--cc-fw-bold); font-size: var(--cc-fs-xs); color: var(--cc-fg-muted); letter-spacing: var(--cc-tracking-wide); text-transform: uppercase; }

    .explain { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 22px; }
    .note { background: var(--cc-yellow-tint); border-left: 4px solid var(--cc-yellow); border-radius: 0 var(--cc-radius-md) var(--cc-radius-md) 0; padding: 16px 20px; font-family: var(--cc-font-body); font-size: var(--cc-fs-sm); line-height: 1.6; color: var(--cc-ink); }
    .note strong { color: var(--cc-ink); font-weight: var(--cc-fw-bold); display: block; }

    /* Accent button (WhatsApp from results) */
    .btn-accent { background: var(--cc-blue); color: var(--cc-yellow); border: 1px solid rgba(37,211,102,0.35); }
    .btn-accent i { color: #25D366; }
    .btn-accent:hover { background: var(--cc-blue-mid); color: var(--cc-yellow-hot); border-color: rgba(37,211,102,0.65); box-shadow: 0 0 16px rgba(37,211,102,0.22); }

    /* ===== FAQ ===== */
    .faq-section { background: var(--cc-paper-warm); padding: 64px 0; border-top: 1px solid var(--cc-border); }
    .faq-inner { max-width: 1180px; margin: 0 auto; padding: 0 32px; }
    .faq-inner h2 { font-family: var(--cc-font-display); font-style: italic; font-weight: var(--cc-fw-black); text-transform: uppercase; font-size: clamp(26px, 2.6vw, 38px); line-height: 1.05; color: var(--cc-ink); margin: 0 0 28px; }
    .faq-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .faq-card { background: var(--cc-paper-card); border: 1px solid var(--cc-border); border-radius: var(--cc-radius-lg); padding: 22px 24px; }
    .faq-card h3 { font-family: var(--cc-font-body); font-size: var(--cc-fs-md); font-weight: var(--cc-fw-bold); color: var(--cc-ink); margin: 0 0 10px; line-height: 1.3; }
    .faq-card p { font-family: var(--cc-font-body); font-size: var(--cc-fs-sm); line-height: var(--cc-lh-loose); color: var(--cc-fg-muted); margin: 0; }

    @media (max-width: 1000px) {
      .sim-wrap { grid-template-columns: 1fr; padding: 40px 24px 80px; }
      .result-grid, .explain { grid-template-columns: 1fr; }
      .score-strip { grid-template-columns: 1fr 1fr; }
      .faq-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 640px) {
      .sim-wrap { padding: 32px 16px 72px; }
      .panel { min-width: 0; padding: 22px; }
      .form-grid { grid-template-columns: 1fr; }
      .actions { flex-direction: column; }
      .actions .cc-btn, .actions .btn { width: 100%; }
      .field, .field input, .field select, .field textarea { min-width: 0; }
      .score-strip { grid-template-columns: 1fr; }
      .faq-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

