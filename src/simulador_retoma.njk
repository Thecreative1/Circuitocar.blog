  <script>
    const form = document.getElementById('tradeInForm');
    const results = document.getElementById('results');

    const euro = new Intl.NumberFormat('pt-PT', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });

    function clamp(value, min, max) { return Math.min(Math.max(value, min), max); }
    function formatEuro(value) { return euro.format(Math.round(value)); }

    function getBaseMarketValue(ano, kms, combustivel, caixa) {
      const currentYear = new Date().getFullYear();
      const idade = currentYear - ano;
      let base = 24000;
      base -= idade * 1500;
      if (kms > 220000) base -= 4500;
      else if (kms > 170000) base -= 3000;
      else if (kms > 130000) base -= 1800;
      else if (kms > 100000) base -= 900;
      else if (kms < 70000) base += 700;
      else if (kms < 40000) base += 1600;
      const fuelAdjust = { gasolina: 0, diesel: -300, hibrido: 1000, plugin: 1600, eletrico: 800, gpl: -500 };
      const caixaAdjust = { manual: 0, automatica: 650 };
      base += fuelAdjust[combustivel] || 0;
      base += caixaAdjust[caixa] || 0;
      return clamp(base, 2500, 90000);
    }

    function getMileageFactor(ano, kms) {
      const currentYear = new Date().getFullYear();
      const idade = Math.max(1, currentYear - ano);
      const expected = idade * 17000;
      const ratio = kms / expected;
      if (ratio <= 0.7) return { factor: 1.04, label: 'Acima da média positiva' };
      if (ratio <= 0.95) return { factor: 1.015, label: 'Ligeiramente favorável' };
      if (ratio <= 1.15) return { factor: 1, label: 'Dentro do esperado' };
      if (ratio <= 1.35) return { factor: 0.95, label: 'Um pouco acima da média' };
      return { factor: 0.89, label: 'Bem acima da média' };
    }

    function getStateFactor(estado) {
      return { excelente: { factor: 1.06, label: 'Estado muito acima da média' }, muito_bom: { factor: 1.03, label: 'Estado forte para revenda' }, bom: { factor: 1, label: 'Estado comercial normal' }, razoavel: { factor: 0.93, label: 'Vai exigir mais desconto' }, fraco: { factor: 0.84, label: 'Desgaste visível pesa bastante' } }[estado];
    }

    function getHistoryFactor(historico) {
      return { completo: { factor: 1.03, label: 'Histórico completo valoriza confiança' }, parcial: { factor: 0.99, label: 'Histórico parcial tem impacto neutro/ligeiro' }, sem_registo: { factor: 0.94, label: 'Sem histórico claro reduz confiança' } }[historico];
    }

    function getOwnersFactor(donos) { return { '1': 1.02, '2': 1, '3': 0.98, '4': 0.95 }[donos] || 1; }
    function getClaimFactor(sinistros) { return { nao: 1, desconhecido: 0.97, sim: 0.9 }[sinistros] || 1; }

    function getLiquidityFactor(liquidez) {
      return { alta: { factor: 1.02, label: 'Boa rotação comercial' }, media: { factor: 1, label: 'Procura equilibrada' }, baixa: { factor: 0.94, label: 'Risco de rotação mais lento' } }[liquidez];
    }

    function getCommercialMargin(idade, liquidez, estado) {
      let margin = 0.16;
      if (idade >= 8) margin += 0.03;
      if (idade >= 12) margin += 0.03;
      if (liquidez === 'baixa') margin += 0.03;
      if (estado === 'razoavel') margin += 0.025;
      if (estado === 'fraco') margin += 0.05;
      return clamp(margin, 0.13, 0.3);
    }

    function getPrepCost(idade, estado, kms, combustivel) {
      let cost = 650;
      if (idade >= 8) cost += 250;
      if (idade >= 12) cost += 300;
      if (estado === 'razoavel') cost += 450;
      if (estado === 'fraco') cost += 950;
      if (kms > 150000) cost += 250;
      if (combustivel === 'plugin' || combustivel === 'eletrico') cost += 150;
      return cost;
    }

    function resultTone(mid, market) {
      const ratio = mid / market;
      if (ratio >= 0.8) return 'Retoma forte face à referência de mercado.';
      if (ratio >= 0.7) return 'Retoma equilibrada para contexto comercial.';
      return 'A diferença reflete preparação, margem e risco de revenda.';
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const data = {
        marca: document.getElementById('marca').value.trim(),
        modelo: document.getElementById('modelo').value.trim(),
        ano: parseInt(document.getElementById('ano').value, 10),
        kms: parseInt(document.getElementById('kms').value, 10),
        combustivel: document.getElementById('combustivel').value,
        caixa: document.getElementById('caixa').value,
        estado: document.getElementById('estado').value,
        historico: document.getElementById('historico').value,
        donos: document.getElementById('donos').value,
        sinistros: document.getElementById('sinistros').value,
        liquidez: document.getElementById('liquidez').value,
        mercado: parseInt(document.getElementById('mercado').value, 10),
        nome: document.getElementById('nome').value.trim(),
        telefone: document.getElementById('telefone').value.trim(),
        objetivo: document.getElementById('objetivo').value,
        observacoes: document.getElementById('observacoes').value.trim()
      };

      const currentYear = new Date().getFullYear();
      const idade = currentYear - data.ano;
      const marketBase = Number.isFinite(data.mercado) ? data.mercado : getBaseMarketValue(data.ano, data.kms, data.combustivel, data.caixa);

      const mileage = getMileageFactor(data.ano, data.kms);
      const state = getStateFactor(data.estado);
      const history = getHistoryFactor(data.historico);
      const liquidity = getLiquidityFactor(data.liquidez);
      const ownersFactor = getOwnersFactor(data.donos);
      const claimFactor = getClaimFactor(data.sinistros);
      const prepCost = getPrepCost(idade, data.estado, data.kms, data.combustivel);
      const margin = getCommercialMargin(idade, data.liquidez, data.estado);

      let adjustedMarket = marketBase;
      adjustedMarket *= mileage.factor;
      adjustedMarket *= state.factor;
      adjustedMarket *= history.factor;
      adjustedMarket *= ownersFactor;
      adjustedMarket *= claimFactor;
      adjustedMarket *= liquidity.factor;
      adjustedMarket = clamp(adjustedMarket, 1500, 120000);

      let tradeMid = adjustedMarket * (1 - margin) - prepCost;
      tradeMid = clamp(tradeMid, 1000, adjustedMarket * 0.92);

      const spread = data.estado === 'fraco' || data.sinistros === 'sim' ? 0.09 : 0.06;
      const low = clamp(tradeMid * (1 - spread), 800, tradeMid);
      const high = clamp(tradeMid * (1 + spread), low + 200, adjustedMarket * 0.97);

      document.getElementById('rangeValue').textContent = `${formatEuro(low)} – ${formatEuro(high)}`;
      document.getElementById('midValue').textContent = formatEuro(tradeMid);
      document.getElementById('marketValue').textContent = formatEuro(adjustedMarket);
      document.getElementById('rangeText').textContent = resultTone(tradeMid, adjustedMarket);

      document.getElementById('scoreEstado').textContent = state.label;
      document.getElementById('scoreKms').textContent = mileage.label;
      document.getElementById('scoreHistorico').textContent = history.label;
      document.getElementById('scoreLiquidez').textContent = liquidity.label;

      const explainLines = [
        `Partimos de uma referência de mercado de ${formatEuro(marketBase)} e ajustámos esse valor pela idade da viatura, quilometragem atual e procura comercial.`,
        `O estado geral foi lido como "${document.querySelector('#estado option:checked').textContent}", o que influencia diretamente o custo de preparação e o desconto necessário para revenda.`,
        `Aplicámos uma margem comercial aproximada de ${(margin * 100).toFixed(0)}% e um custo médio de preparação de ${formatEuro(prepCost)}.`
      ];
      document.getElementById('explainText').innerHTML = explainLines.map(line => `<p style="margin:0 0 10px;">${line}</p>`).join('');

      let next = 'Envie fotos exteriores, interiores, matrícula e versão exata para afinar a avaliação final.';
      if (data.objetivo === 'sim') {
        next = 'Como pretende trocar de carro, o melhor passo seguinte é cruzar esta estimativa com o stock disponível e perceber quanto poderá reduzir no financiamento.';
      } else if (data.objetivo === 'talvez') {
        next = 'Tem uma base útil para decidir se faz sentido avançar para avaliação completa ou comparar com outra viatura em stock.';
      }
      document.getElementById('nextStepText').textContent = next;

      const msg = [
        `Olá, sou ${data.nome}.`,
        `Fiz uma simulação de retoma para ${data.marca} ${data.modelo} (${data.ano}) com ${data.kms.toLocaleString('pt-PT')} km.`,
        `A faixa indicativa apresentada foi ${formatEuro(low)} a ${formatEuro(high)}.`,
        `Gostava de afinar a avaliação.${data.observacoes ? ` Observações: ${data.observacoes}` : ''}`
      ].join(' ');

      document.getElementById('whatsappBtn').href = `https://wa.me/351922017034?text=${encodeURIComponent(msg)}`;

      results.classList.add('active');
      results.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>

  <script src="https://unpkg.com/lucide@latest"></script>
  <script>lucide.createIcons();</script>
